# ==========================================
# OptiFlow AI — Configuration Production
# ==========================================
# Copier ce fichier en .env et remplir les valeurs

# --- Application ---
APP_ENV=production

# --- Base de donnees (CHANGER le mot de passe !) ---
POSTGRES_DB=optiflow
POSTGRES_USER=optiflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql+psycopg://optiflow:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/optiflow

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Stockage S3/MinIO (CHANGER les credentials !) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
S3_BUCKET=optiflow-docs

# --- Authentification (CHANGER le secret !) ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api/v1

# --- Email SMTP (configurer un vrai serveur SMTP en prod) ---
MAILHOG_SMTP_HOST=smtp.your-provider.com
MAILHOG_SMTP_PORT=587

# --- IA (optionnel) ---
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# --- Cosium (optionnel) ---
COSIUM_BASE_URL=https://c1.cosium.biz
COSIUM_TENANT=your-tenant
COSIUM_LOGIN=your-login
COSIUM_PASSWORD=your-password
