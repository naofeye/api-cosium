# ==========================================
# OptiFlow AI — Configuration Production
# ==========================================
# Copier ce fichier en .env et remplir les valeurs

# --- Application ---
APP_ENV=production

# --- Base de donnees (CHANGER le mot de passe !) ---
POSTGRES_DB=optiflow
POSTGRES_USER=optiflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql+psycopg://optiflow:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/optiflow

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Stockage S3/MinIO (CHANGER les credentials !) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
S3_BUCKET=optiflow-docs

# --- Authentification (CHANGER le secret !) ---
# JWT_SECRET : >=32 caracteres, refuse en prod si "change-me" present
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Chiffrement (OBLIGATOIRE en production/staging) ---
# Generer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# --- CORS (jamais "*" en prod) ---
CORS_ORIGINS=https://your-domain.com

# --- Upload ---
MAX_UPLOAD_SIZE_MB=20

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api/v1

# --- Email SMTP (configurer un vrai serveur SMTP en prod) ---
MAILHOG_SMTP_HOST=smtp.your-provider.com
MAILHOG_SMTP_PORT=587

# --- Monitoring (optionnel) ---
SENTRY_DSN=

# --- IA (optionnel) ---
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# --- Stripe (facturation SaaS, optionnel) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_RESEAU=
STRIPE_PRICE_IA_PRO=

# --- Cosium (optionnel) ---
COSIUM_BASE_URL=https://c1.cosium.biz
COSIUM_TENANT=your-tenant
COSIUM_LOGIN=your-login
COSIUM_PASSWORD=your-password
