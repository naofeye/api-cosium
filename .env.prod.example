# OptiFlow .env.prod.example
# Copier en .env.prod sur le serveur, remplir tous les champs.
# Voir docs/ENV.md pour la description exhaustive de chaque variable.

# === Application ===
APP_ENV=production
SEED_ON_STARTUP=false

# === Database PostgreSQL ===
# OBLIGATOIRE : password fort >= 32 chars
POSTGRES_DB=optiflow
POSTGRES_USER=optiflow
POSTGRES_PASSWORD=__CHANGE_ME_strong_db_password__
DATABASE_URL=postgresql+psycopg://optiflow:__CHANGE_ME_strong_db_password__@postgres:5432/optiflow

# === Auth & Encryption ===
# OBLIGATOIRE : generer avec
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=__CHANGE_ME_64_chars_random__

# OBLIGATOIRE : generer avec
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=__CHANGE_ME_fernet_key__

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === CORS ===
# Strict en prod : domaines specifiques uniquement, JAMAIS *
CORS_ORIGINS=https://app.optiflow.example.com

# Origine frontend pour les emails (reset password, invitations, etc.)
# OBLIGATOIRE en prod : sans cette variable, les liens des emails utilisent
# le premier CORS_ORIGINS, ce qui peut produire un lien partiellement faux
# si l'ordre CORS_ORIGINS change.
FRONTEND_BASE_URL=https://app.optiflow.example.com

# === Rate limiter X-Forwarded-For (CRITIQUE derriere nginx) ===
# Sans cette variable, le rate limiter bucketise toutes les requetes sur l'IP
# du proxy/container : un seul utilisateur peut bloquer tout le monde.
# Mettre les IPs des reverse proxies de confiance (CSV) — typiquement
# "127.0.0.1" en deploiement docker compose avec nginx local.
TRUSTED_PROXIES=127.0.0.1

# === S3 / MinIO ===
# OBLIGATOIRE : credentials non-defaut
S3_ENDPOINT=http://minio:9000
# Endpoint public HTTPS utilise pour les URLs presignees servies au navigateur.
# `S3_ENDPOINT` est un hostname Docker interne (`minio`), non resolvable depuis
# l'exterieur. En prod, mettre ici l'URL publique exposee par le reverse-proxy.
S3_PUBLIC_ENDPOINT=https://minio.optiflow.example.com
S3_ACCESS_KEY=__CHANGE_ME_s3_user__
S3_SECRET_KEY=__CHANGE_ME_s3_password_strong__
S3_BUCKET=optiflow-docs

# === Redis & Celery ===
REDIS_URL=redis://redis:6379/0

# === Email (SMTP prod, pas Mailhog) ===
# Sendgrid / SES / OVH / Mailgun
MAILHOG_SMTP_HOST=smtp.sendgrid.net
MAILHOG_SMTP_PORT=587
# SMTP_USER + SMTP_PASS si auth requise

# === Anthropic Claude (IA) ===
ANTHROPIC_API_KEY=sk-ant-__CHANGE_ME__
AI_MODEL=claude-haiku-4-5-20251001

# === Stripe (facturation OptiFlow SaaS) ===
STRIPE_SECRET_KEY=sk_live___CHANGE_ME__
STRIPE_WEBHOOK_SECRET=whsec___CHANGE_ME__
STRIPE_PRICE_SOLO=price___CHANGE_ME__
STRIPE_PRICE_RESEAU=price___CHANGE_ME__
STRIPE_PRICE_IA_PRO=price___CHANGE_ME__

# === Cosium (LECTURE SEULE — voir docs/COSIUM_AUTH.md) ===
COSIUM_BASE_URL=https://c1.cosium.biz
COSIUM_TENANT=__CHANGE_ME_tenant_slug__
COSIUM_LOGIN=optiflow-readonly
COSIUM_PASSWORD=__CHANGE_ME_cosium_password__
# OIDC alternatif (laisser vide si Basic auth utilise)
COSIUM_OIDC_TOKEN_URL=
COSIUM_OIDC_CLIENT_ID=
# Cookies (mode interactif dev only — vide en prod)
COSIUM_ACCESS_TOKEN=
COSIUM_DEVICE_CREDENTIAL=

# === Upload ===
MAX_UPLOAD_SIZE_MB=20

# === Frontend (Next.js build-time) ===
NEXT_PUBLIC_API_BASE_URL=https://app.optiflow.example.com/api/v1
NEXT_PUBLIC_SENTRY_DSN=https://__CHANGE_ME__@sentry.io/__project__

# === Monitoring ===
SENTRY_DSN=https://__CHANGE_ME__@sentry.io/__project__

# === Backups ===
BACKUP_RETENTION_DAYS=90
BACKUP_MIN_FREE_MB=1000
BACKUP_ALERT_WEBHOOK=https://hooks.slack.com/services/__CHANGE_ME__
MAX_AGE_HOURS=25

# === Deploy ===
DEPLOY_BRANCH=main

# === Monitoring stack (optionnel) ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=__CHANGE_ME_grafana_password__
