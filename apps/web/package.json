    "@types/react": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
