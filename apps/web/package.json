    "@types/react-big-calendar": "^1.16.3",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^1.7.0",
    "next": "15.4.6",
    "next-nprogress-bar": "^2.4.7",
    "postcss": "^8.5.8",
    "react": "19.1.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
