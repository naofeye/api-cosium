# === OptiFlow AI - Variables d'environnement ===

# App
APP_ENV=local

# Database
POSTGRES_DB=optiflow
POSTGRES_USER=optiflow
POSTGRES_PASSWORD=optiflow
DATABASE_URL=postgresql+psycopg://optiflow:optiflow@postgres:5432/optiflow
REDIS_URL=redis://redis:6379/0

# Auth (CHANGER en production !)
JWT_SECRET=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (laisser vide en dev — derive du JWT_SECRET)
ENCRYPTION_KEY=

# CORS (separer par virgule si plusieurs origines)
CORS_ORIGINS=http://localhost:3000

# Storage (MinIO/S3)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=optiflow-docs

# Email (Mailhog en dev, SMTP reel en prod)
MAILHOG_SMTP_HOST=mailhog
MAILHOG_SMTP_PORT=1025

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Cosium API (LECTURE SEULE — ne jamais ecrire dans Cosium)
COSIUM_BASE_URL=https://c1.cosium.biz
COSIUM_TENANT=
COSIUM_LOGIN=
COSIUM_PASSWORD=

# Monitoring (optionnel)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# IA Anthropic (optionnel)
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# Stripe - Facturation SaaS (optionnel)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_RESEAU=
STRIPE_PRICE_IA_PRO=
