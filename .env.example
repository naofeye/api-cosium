# === OptiFlow AI - Variables d'environnement ===

# App
APP_ENV=local

# Database
POSTGRES_DB=optiflow
POSTGRES_USER=optiflow
POSTGRES_PASSWORD=optiflow
DATABASE_URL=postgresql+psycopg://optiflow:optiflow@postgres:5432/optiflow
REDIS_URL=redis://redis:6379/0

# Auth — OBLIGATOIRE en production (generer un secret aleatoire de 64+ caracteres)
JWT_SECRET=dev-only-change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption — OBLIGATOIRE en production
# Generer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# CORS (separer par virgule si plusieurs origines)
CORS_ORIGINS=http://localhost:3000

# Origine frontend pour les emails (reset password, invitations, etc.)
# Si vide, l'API retombe sur le premier element de CORS_ORIGINS — fragile.
# Mettre l'URL HTTPS publique du frontend en staging/prod.
FRONTEND_BASE_URL=http://localhost:3000

# Trusted proxies (CSV d'IPs) — IPs autorisees a fournir un header X-Forwarded-For
# fiable. Vide par defaut : le rate limiter utilise alors l'IP TCP directe.
# En production derriere nginx local, ajouter "127.0.0.1".
TRUSTED_PROXIES=

# Upload
MAX_UPLOAD_SIZE_MB=20

# Storage (MinIO/S3)
S3_ENDPOINT=http://minio:9000
# Endpoint public utilise pour les URLs presignees servies au navigateur.
# Vide en dev local : on retombe sur S3_ENDPOINT (host docker `minio`).
# En prod : URL HTTPS publique du MinIO/S3, ex `https://minio.optiflow.example.com`.
S3_PUBLIC_ENDPOINT=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=optiflow-docs

# Email (Mailhog en dev, SMTP reel en prod)
MAILHOG_SMTP_HOST=mailhog
MAILHOG_SMTP_PORT=1025

# Runtime flags
SEED_ON_STARTUP=true
CELERY_WORKER=false

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Cosium API (LECTURE SEULE — ne jamais ecrire dans Cosium)
COSIUM_BASE_URL=https://c1.cosium.biz
COSIUM_TENANT=
COSIUM_LOGIN=
COSIUM_PASSWORD=

# Cosium cookies (copier depuis DevTools si auth basic echoue)
COSIUM_ACCESS_TOKEN=
COSIUM_DEVICE_CREDENTIAL=

# Cosium OIDC (si active par Cosium — alternative a l'auth basic)
COSIUM_OIDC_TOKEN_URL=
COSIUM_OIDC_CLIENT_ID=

# Monitoring (optionnel)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# IA Anthropic (optionnel)
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# Stripe - Facturation SaaS (optionnel)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_RESEAU=
STRIPE_PRICE_IA_PRO=
