                    controller: ['$log', '$scope', '$location', 'Base64Service', function ($log, $scope, $location, Base64Service) {
                        $log = $log.getInstance('LegacyController');
                        var theLegacyDestination;
                        var params = $location.search();
                        if (params.p && !params.s) {
                            var payload = JSON.parse(Base64Service.decode(params.p));
                            var urlName = payload[0];
                            var parameters = '';
                            if (payload.length > 1) {
                                parameters = payload[1];
                            }
                            var suffix = '';
                            if (payload.length > 2) {
                                suffix = payload[2];
                            }
                            if (parameters) {
                                parameters = parameters.replace(/\${(.*)}/, function (match, token) {
                                    return CTR.Url[token];
                                });
                            }
                            theLegacyDestination = (CTR.Url[urlName] || urlName) + suffix + (parameters ? '?' + parameters : '');
                            CTR.Legacy.destination = theLegacyDestination;
                            $location.search('p', null);
                            $location.search('s', null);
                            return;
                        } else if (params.p && params.s) {
                            theLegacyDestination = Base64Service.decode(params.p);
                            CTR.Legacy.destination = theLegacyDestination;
                            $location.search('p', null);
                            $location.search('s', null);
                            return;
                        } else {
                            theLegacyDestination = CTR.Legacy.destination;
                        }

                        $log.debug('Destination is "' + theLegacyDestination + '"');
                        $scope.destination = theLegacyDestination;
                    }]
