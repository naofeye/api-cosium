angular.module('center')
    .component('legacyView', {
        bindings: {
            destination: '<',
            frameHeight: '@'
        },
        template: '<div ng-bind-html="$ctrl.renderMainFrame()"></div>',
        controller: ['$scope', '$log', '$sce', '$cookies', '$location', 'UserContextService', 'signInHandler', 'Base64Service',  function ($scope, $log, $sce, $cookies, $location, UserContextService, signInHandler, base64Service) {
            $log = $log.getInstance('legacyViewDirective');

            var self = this;

            this.$onInit = function () {
                var legacyFrameName = $cookies.get('main-frame-name') || CTR.Legacy.frameName;
                var theLegacyDestination = self.destination;

                window.angularInjector = angular.element(document.querySelector('[ng-controller]')).injector();

                /**
                 * Cache of all listener destroy callbacks
                 * @type {Array}
                 */
                var currentScopeListeners = [];
                window.angularScope = $scope;
                $scope.$on('$destroy', function() {
                    if (window.angularScope !== $scope) {
                        return;
                    }
                    window.angularScope = null;
                });

                var legacyOn = $scope.$on;
                $scope.$on = function () {
                    var listener = legacyOn.apply(this, arguments);
                    currentScopeListeners.push(listener);
                    return listener;
                };

                var beforeMainFrameUnLoad = function() {
                    $log.debug('Destroying ' + currentScopeListeners.length + ' scope listeners');
                    currentScopeListeners.forEach(function (cb) {
                        cb();
                    });
                    currentScopeListeners = [];
                };
                window.onLoadedMainFrame = function (contentWindow) {
                  UserContextService.refreshLegacyContext();

                  const currentLocationHashProvider = () => {
                    const payload = JSON.stringify([contentWindow.location.pathname]);
                    const p = base64Service.encode(payload);
                    return `#/l?p=${p}`;
                  };
                  signInHandler.registerCurrentLocationHashProvider(currentLocationHashProvider);
                  contentWindow.addEventListener('unload', () => signInHandler.unRegisterCurrentLocationHashProvider(currentLocationHashProvider), {once: true});
                  contentWindow.addEventListener('unload', beforeMainFrameUnLoad.bind(self), {once: true});
                };


                if (!self.frameHeight) {
                    self.frameHeight = 'calc(100vh - 81px)';
                }

                self.renderMainFrame = function () {
                    var html = '<iframe onLoad="onLoadedMainFrame(this.contentWindow);" ' +
                        'style="left:1px; z-index: 1019; display: block; border: none; margin: 0; padding: 0; width:100%; height: ' + self.frameHeight + '; overflow: hidden;" ' +
                        'name="' + legacyFrameName + '" id="AudiOpticCenter" src="' + theLegacyDestination + '"></iframe>';
                    return $sce.trustAsHtml(html);
                };
            };

        }]
    });

angular.module('center').service('legacyUserContextDestructionService', ['$log', 'UserContextService', function ($log, UserContextService) {
    $log = $log.getInstance('legacyUserContextDestructionService');

    var self = this;
    this.init = function () {
        UserContextService.$promise.then(function (userContext) {
            $log.debug('Subscribing to user context destruction');
            userContext.destructionPromise.then(function () {
                $log.debug('Resetting to default destination: ' + CTR.Legacy.defaultDestination);
                CTR.Legacy.destination = CTR.Legacy.defaultDestination;
                self.init();
            });
        })
    }
}])
    .run(['legacyUserContextDestructionService', function (legacyUserContextDestructionService) {
        legacyUserContextDestructionService.init();
    }]);
